{
  "name": "exeos-AI",
  "version": "0.1.0",
  "private": true,
  "description": "A full-stack workflow automation platform inspired by n8n, enabling users to visually design, execute, and monitor complex automation pipelines using a node-based interface. Engineered with Next.js, TypeScript, and modern backend architecture, the platform integrates AI models from OpenAI, Anthropic, and Gemini to power intelligent workflow execution, content generation, and decision-making. Implemented secure authentication, real-time workflow orchestration, background job processing, API integrations, execution history, and scalable state management, following production-grade software engineering practices.",
  "scripts": {
    "dev": "next dev -p 4040 --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .next",
    "format:check": "prettier . --check",
    "typecheck:exact": "tsc --noEmit --exactOptionalPropertyTypes",
    "lint:fix": "next lint --fix",
    "prepare": "husky",
    "check": "bun run lint && bun run typecheck"
  },
  "dependencies": {
    "-": "^0.0.1-security.1",
    "@base-ui/react": "^1.6.0",
    "@clerk/nextjs": "^7.5.12",
    "@clerk/ui": "^1.24.1",
    "@neondatabase/serverless": "^1.1.0",
    "@shadcn/react": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "embla-carousel-react": "^8.6.0",
    "googleapis": "^173.0.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "postgres": "^3.4.9",
    "prettier": "^3.9.4",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.12.1",
    "recharts": "3.8.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^1.0.0-rc.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
